# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here   # Never expose to browser

# ── AI Providers ──────────────────────────────────────────────────────────────
# System-level fallback keys (workspace keys stored encrypted in DB)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
APP_ENCRYPTION_SECRET=32-char-random-string-here        # openssl rand -hex 16

# ── Optional: Redis (Phase 2) ─────────────────────────────────────────────────
# REDIS_URL=redis://localhost:6379
